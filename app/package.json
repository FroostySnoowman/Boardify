    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.14",
    "jest": "^30.3.0",
    "react-native-svg-transformer": "^1.5.3",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.9",
    "typescript": "~6.0.3"
