{
  "name": "boardify",
  "version": "1.0.0",
  "main": "AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "npx expo export --platform web",
    "prebuild:android": "npx expo prebuild --platform android",
    "build:android": "npx expo prebuild --platform android && cd android && ./gradlew assembleRelease",
    "build:android:debug": "npx expo prebuild --platform android && cd android && ./gradlew assembleDebug",
    "build:ios:prod": "EXPO_PUBLIC_BUILD_ENV=production NODE_ENV=production npx expo prebuild --clean --platform ios",
    "build:ios:dev": "npx expo prebuild --clean --platform ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "56.0.0-canary-20260423-c31bd8e",
    "@expo/ui": "56.0.0-canary-20260423-c31bd8e",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/core": "^7.17.2",
    "@react-navigation/elements": "^2.9.15",
    "@react-navigation/native": "^7.2.2",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "babel-plugin-module-resolver": "^5.0.3",
