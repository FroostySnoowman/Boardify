{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview-apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_INCLUDE_SANDBOX_SUBSCRIPTIONS": "false"
      },
      "ios": {
        "simulator": false
      }
    },
    "testflight": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_INCLUDE_SANDBOX_SUBSCRIPTIONS": "true"
      },
      "ios": {
        "simulator": false
      }
    },
    "production-apk": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "production": {}
  }
}
